# ── .gitignore cho Terraform ────────────────────────────────

# State files — chứa thông tin nhạy cảm, lưu trên S3 thay vì Git
*.tfstate
*.tfstate.*
*.tfstate.backup

# Thư mục cache của Terraform
.terraform/
.terraform.lock.hcl

# Var files có thể chứa secrets
*.tfvars
!dev.tfvars      # ngoại trừ dev.tfvars (không có secrets)

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
